{
  "manifest_version": 3,
  "name": "Encrypted Clipboard Manager - History, Secure Sync & Snippets",
  "short_name": "ECM",
  "version": "5.4.0",
  "description": "Zero-knowledge encrypted clipboard with cross-device sync, code snippets, PIN lock, quick capture. Source available on GitHub.",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "clipboardRead",
    "clipboardWrite",
    "offscreen",
    "alarms",
    "contextMenus",
    "notifications",
    "system.display",
    "downloads",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "optional_permissions": [],
  "action": {
    "default_icon": {
      "16": "assets/icons/icon.png",
      "48": "assets/icons/icon.png",
      "128": "assets/icons/icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/index.html"
  },
  "icons": {
    "16": "assets/icons/icon.png",
    "48": "assets/icons/icon.png",
    "128": "assets/icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/element-picker.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://encryptedclipboard.app/*"],
      "js": ["content/auth-sync.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["content/github-url-copy.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content/twitter-url-copy.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/linkedin-url-copy.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube-url-copy.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://app.ahrefs.com/*"],
      "js": ["content/ahrefs-backlinks-csv.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/snippets.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "open_clipboard_window": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Alt+Shift+E",
        "linux": "Alt+Shift+E"
      },
      "description": "Open Clipboard Manager in a floating window"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/snippets-inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
