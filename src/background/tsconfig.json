{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["chrome", "node"],
    "paths": {
      "@/*": ["../*"],
      "@config": ["../config"],
      "@shared/*": ["../shared/*"],
      "@encryptedclipboard/crypto": [
        "../../node_modules/@encryptedclipboard/crypto"
      ]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
